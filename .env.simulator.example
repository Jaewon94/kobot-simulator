# KOBOT 시뮬레이터 환경 변수 설정 파일
# 사용법: .env.simulator.example을 .env.simulator로 복사 후 수정

# ============================================================================
# 환경 설정 (development / production)
# ============================================================================
ENVIRONMENT=development

# ============================================================================
# 실행 모드 선택 (3가지)
# ============================================================================
#
# 1️⃣ 같은 컴퓨터에서 실행 (개발/테스트):
#    cd simulator && docker compose -f docker-compose.simulator.yml up -d
#    → 호스트 네트워크를 통해 관제 시스템에 접속 (외부처럼 동작)
#    설정:
#      MQTT_BROKER=host.docker.internal (Mac/Windows)
#      MQTT_BROKER=172.17.0.1 (Linux)
#      MEDIAMTX_HOST=host.docker.internal
#
# 2️⃣ 다른 컴퓨터에서 실행 (실제 KOBOT 시뮬레이션):
#    1. simulator 폴더만 복사
#    2. .env.simulator 수정:
#       MQTT_BROKER=192.168.1.100 (관제 서버 IP)
#       MEDIAMTX_HOST=192.168.1.100
#    3. docker compose -f docker-compose.simulator.yml up -d
#    → 네트워크를 통해 원격 관제 시스템에 접속
#
# 3️⃣ 운영 환경 (AWS EC2, 도메인 사용):
#    MQTT_BROKER=kobot.example.com
#    MQTT_PORT=8883  # TLS
#    MEDIAMTX_HOST=kobot.example.com
#
# ============================================================================

# ============================================================================
# MQTT 브로커 설정
# ============================================================================
# 같은 컴퓨터: host.docker.internal (Mac/Windows) 또는 172.17.0.1 (Linux)
# 다른 컴퓨터: 관제 시스템 서버의 IP 또는 도메인
#   예시: 192.168.1.100, 172.16.0.50, kobot.example.com
MQTT_BROKER=host.docker.internal
MQTT_PORT=1883

# 운영 환경 TLS 사용 시:
# MQTT_BROKER=kobot.example.com
# MQTT_PORT=8883

# ============================================================================
# MediaMTX 설정
# ============================================================================
# 같은 컴퓨터: host.docker.internal (Mac/Windows) 또는 172.17.0.1 (Linux)
# 다른 컴퓨터: 관제 시스템 서버의 IP 또는 도메인
MEDIAMTX_HOST=host.docker.internal
MEDIAMTX_RTMP_PORT=1935

# 운영 환경:
# MEDIAMTX_HOST=kobot.example.com
# MEDIAMTX_RTMP_PORT=1935

# ============================================================================
# KOBOT #11 설정 (kobot-sim-011)
# ============================================================================
KOBOT_011_NAMESPACE=kobot11
KOBOT_011_NAME=KOBOT-SIM-011
KOBOT_011_USERNAME=kobot11
KOBOT_011_PASSWORD=your_password_here
KOBOT_011_ROS_DOMAIN_ID=11
KOBOT_011_INITIAL_LAT=35.140000
KOBOT_011_INITIAL_LON=129.180000
KOBOT_011_INITIAL_ALT=0.0
KOBOT_011_SCENARIO=patrol

# ============================================================================
# KOBOT #12 설정 (kobot-sim-012)
# ============================================================================
KOBOT_012_NAMESPACE=kobot12
KOBOT_012_NAME=KOBOT-SIM-012
KOBOT_012_USERNAME=kobot12
KOBOT_012_PASSWORD=your_password_here
KOBOT_012_ROS_DOMAIN_ID=12
KOBOT_012_INITIAL_LAT=35.142000
KOBOT_012_INITIAL_LON=129.182000
KOBOT_012_INITIAL_ALT=0.0
KOBOT_012_SCENARIO=patrol

# ============================================================================
# KOBOT #13 설정 (kobot-sim-013)
# ============================================================================
KOBOT_013_NAMESPACE=kobot13
KOBOT_013_NAME=KOBOT-SIM-013
KOBOT_013_USERNAME=kobot13
KOBOT_013_PASSWORD=your_password_here
KOBOT_013_ROS_DOMAIN_ID=13
KOBOT_013_INITIAL_LAT=35.144000
KOBOT_013_INITIAL_LON=129.178000
KOBOT_013_INITIAL_ALT=0.0
KOBOT_013_SCENARIO=stationary

# ============================================================================
# KOBOT #14 설정 (kobot-sim-014)
# ============================================================================
KOBOT_014_NAMESPACE=kobot14
KOBOT_014_NAME=KOBOT-SIM-014
KOBOT_014_USERNAME=kobot14
KOBOT_014_PASSWORD=your_password_here
KOBOT_014_ROS_DOMAIN_ID=14
KOBOT_014_INITIAL_LAT=35.138000
KOBOT_014_INITIAL_LON=129.184000
KOBOT_014_INITIAL_ALT=0.0
KOBOT_014_SCENARIO=patrol

# ============================================================================
# KOBOT #15 설정 (kobot-sim-015)
# ============================================================================
KOBOT_015_NAMESPACE=kobot15
KOBOT_015_NAME=KOBOT-SIM-015
KOBOT_015_USERNAME=kobot15
KOBOT_015_PASSWORD=your_password_here
KOBOT_015_ROS_DOMAIN_ID=15
KOBOT_015_INITIAL_LAT=35.136000
KOBOT_015_INITIAL_LON=129.186000
KOBOT_015_INITIAL_ALT=0.0
KOBOT_015_SCENARIO=patrol

# ============================================================================
# 센서 발행 주기 설정
# ============================================================================
# 센서 데이터 발행 빈도 (Hz = 초당 발행 횟수)
# 예: 0.2Hz = 5초마다 1회, 0.33Hz = 3초마다 1회, 1.0Hz = 1초마다 1회
GPS_RATE=0.2          # GPS 센서 (기본: 5초마다 1회)
IMU_RATE=0.2          # IMU 센서 (기본: 5초마다 1회)
LIDAR_RATE=0.33       # LiDAR 센서 (기본: 3초마다 1회)
STATUS_RATE=0.2       # System Status (기본: 5초마다 1회)

# ============================================================================
# 카메라 스트리밍 설정
# ============================================================================
# 시뮬레이터 시작 시 자동으로 카메라 스트리밍 시작 여부
# - true: 시뮬레이터 시작하면 즉시 3채널 카메라 스트리밍 시작 (개발 환경 권장)
# - false: 수동으로 fake_stream.sh 실행 필요 (리소스 절약, CI/테스트)
CAMERA_AUTO_START=true

CAMERA_RESOLUTION=1280x720
CAMERA_FPS=30
CAMERA_BITRATE=2M

# ============================================================================
# 로깅 설정
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
